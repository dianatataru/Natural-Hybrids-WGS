echo "Start Job"

module load plink/1.9

cd /lustre/project/kferris/Diana_Tataru/hybrids/4_GATKvarcall/3_Genotyped_GVCFs/

plink --vcf hybrid1_jointgeno_v2.vcf --make-bed --keep-allele-order --out hybrid1_plink

